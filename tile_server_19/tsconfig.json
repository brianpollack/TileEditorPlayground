{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client",
      "@vitejs/plugin-rsc/types"
    ],
    "baseUrl": "."
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}
